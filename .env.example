# =============================================================
# Agora Configuration
# =============================================================
# Agora is local-first and cloud-compatible; optional cloud model endpoints can be used.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== Flask / Security =====
# Pflicht im Nicht-Debug-Betrieb. Erzeuge einen neuen Wert mit:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-use-token_urlsafe-32

# Default ist false (secure-by-default). Auf true setzen für lokale Entwicklung
# mit Hot-Reload und Tracebacks in API-Responses. Niemals in Prod aktivieren.
FLASK_DEBUG=true

# Bind-Adresse des Flask-Servers. Default: 127.0.0.1 (nur lokal erreichbar).
# Im Docker-Container setzt das Dockerfile automatisch 0.0.0.0.
# FLASK_HOST=127.0.0.1

# ===== LLM Configuration (OpenAI-compatible format) =====
# Points to local Ollama server. Any non-empty value for API key works.
# In Docker, Agora reaches host Ollama through host.docker.internal.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
# Lighter model for development (less VRAM):
# LLM_MODEL_NAME=qwen2.5:14b

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Pflichtfeld. Kein Default mehr — docker-compose bricht bei leerem Wert ab.
NEO4J_PASSWORD=change-me

# ===== Embedding Configuration =====
# Uses Ollama's embedding endpoint
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# For Docker with host Ollama: EMBEDDING_BASE_URL=http://host.docker.internal:11434

# ===== Agent Tool-Use during Simulation =====
# Experimental and opt-in. When enabled, simulation agents can query
# the knowledge graph before deciding actions. This is slower and adds LLM calls.
# ENABLE_AGENT_TOOLS=false
# MAX_TOOL_CALLS_PER_ACTION=2

# ===== Time / Locale Profile =====
# Default: German/DACH social activity profile (Europe/Berlin).
TIME_PROFILE=dach_default

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to same local Ollama server
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Docker-mode overrides =====
# Uncomment these when using Docker Compose with host Ollama
# (backend container talks to Neo4j by service name and host Ollama via extra_hosts)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# OPENAI_API_BASE_URL=http://host.docker.internal:11434/v1
