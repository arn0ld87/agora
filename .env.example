# =============================================================
# Agora Configuration
# =============================================================
# Agora is local-first and cloud-compatible; optional cloud model endpoints can be used.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== Flask / Security =====
# Pflicht im Nicht-Debug-Betrieb. Erzeuge einen neuen Wert mit:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-use-token_urlsafe-32

# Default ist false (secure-by-default). Auf true setzen für lokale Entwicklung
# mit Hot-Reload und Tracebacks in API-Responses. Niemals in Prod aktivieren.
FLASK_DEBUG=true

# Bind-Adresse des Flask-Servers. Default: 127.0.0.1 (nur lokal erreichbar).
# Im Docker-Container setzt das Dockerfile automatisch 0.0.0.0.
# FLASK_HOST=127.0.0.1

# Optionaler API-Token-Schutz für /api/*.
# Wenn gesetzt, muss der Client den Header `Authorization: Bearer <token>` senden.
# AGORA_AUTH_TOKEN=change-me

# Zusätzliche erlaubte Frontend-Origins (kommagetrennt), z.B. Tailscale / LAN.
# AGORA_EXTRA_ORIGINS=http://100.64.0.10:5173,https://agora.tailnet.example

# ===== LLM Configuration (OpenAI-compatible format) =====
# Points to local Ollama server. Any non-empty value for API key works.
# In Docker, Agora reaches host Ollama through host.docker.internal.
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
# Lighter model for development (less VRAM):
# LLM_MODEL_NAME=qwen2.5:14b

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Pflichtfeld. Kein Default mehr — docker-compose bricht bei leerem Wert ab.
NEO4J_PASSWORD=change-me

# ===== Embedding Configuration =====
# Aktuell empfohlener Pfad: Qwen3 Embeddings (2560 Dimensionen)
EMBEDDING_MODEL=qwen3-embedding:4b
EMBEDDING_BASE_URL=http://localhost:11434
VECTOR_DIM=2560

# Fallback für kleinere / ältere Setups:
# EMBEDDING_MODEL=nomic-embed-text
# VECTOR_DIM=768

# Agora validiert das Embedding beim Start mit einer echten Probe.
# Wenn EMBEDDING_MODEL / VECTOR_DIM nicht zusammenpassen, startet das Backend nicht.
# For Docker with host Ollama: EMBEDDING_BASE_URL=http://host.docker.internal:11434

# ===== Hybrid Search Weights =====
# SearchService kombiniert Vector-Score und BM25-Keyword-Score gewichtet.
# Defaults reproduzieren das alte Verhalten (0.7 / 0.3); per Graph
# tuneable, falls die Mischung in der Praxis daneben liegt. Die Werte
# müssen sich nicht zu 1.0 summieren — beide Seiten werden vor dem Mix
# normalisiert.
# HYBRID_SEARCH_VECTOR_WEIGHT=0.7
# HYBRID_SEARCH_KEYWORD_WEIGHT=0.3

# ===== Agent Tool-Use during Simulation =====
# Experimental and opt-in. When enabled, simulation agents can query
# the knowledge graph before deciding actions. This is slower and adds LLM calls.
# ENABLE_AGENT_TOOLS=false
# MAX_TOOL_CALLS_PER_ACTION=2

# ===== Event Bus (Issue #9 Phase B) =====
# Transport für die Flask↔OASIS-Subprozess-IPC (Pause/Resume/Interview/State).
# `auto` (Default) probiert Redis und fällt auf File-Polling zurück, falls
# REDIS_URL nicht erreichbar ist. `redis` erzwingt Redis (Startup-Fail wenn down).
# `file` behält das Pre-Issue-9-Verhalten (reiner File-Poll-Loop).
# EVENT_BUS_BACKEND=auto
REDIS_URL=redis://redis:6379/0

# ===== Logging =====
# `text` = menschenlesbar, `json` = strukturierte Logs für zentrale Auswertung.
# AGORA_LOG_FORMAT=text

# ===== Time / Locale Profile =====
# Default: German/DACH social activity profile (Europe/Berlin).
TIME_PROFILE=dach_default
AGENT_LANGUAGE=de
REPORT_LANGUAGE=German

# ===== Optional Webtools for ReportAgent =====
# ENABLE_WEB_TOOLS=true
# TAVILY_API_KEY=your-key-here

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to same local Ollama server
OPENAI_API_KEY=ollama
OPENAI_API_BASE_URL=http://localhost:11434/v1

# ===== Docker-mode overrides =====
# Uncomment these when using Docker Compose with host Ollama
# (backend container talks to Neo4j by service name and host Ollama via extra_hosts)
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# OPENAI_API_BASE_URL=http://host.docker.internal:11434/v1
